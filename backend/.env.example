# Backend runtime environment template
# Copy values into your deployment environment; do not commit filled secrets.

# Profile: dev/test/prod. Production fail-fast checks are enabled when set to prod.
SPRING_PROFILES_ACTIVE=dev

# Server
TRACE_SERVER_PORT=8080

# Database
TRACE_DB_URL=jdbc:mysql://<db-host>:3306/<db-name>?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
TRACE_DB_USERNAME=<replace-with-db-username>
TRACE_DB_PASSWORD=<replace-with-db-password>
TRACE_DB_DRIVER=com.mysql.cj.jdbc.Driver

# Redis
TRACE_REDIS_HOST=<replace-with-redis-host>
TRACE_REDIS_PORT=6379
TRACE_REDIS_DATABASE=0
TRACE_REDIS_PASSWORD=<replace-with-redis-password-or-empty>
TRACE_REDIS_TIMEOUT=3000ms
TRACE_REDIS_POOL_MAX_ACTIVE=8
TRACE_REDIS_POOL_MAX_IDLE=8
TRACE_REDIS_POOL_MIN_IDLE=0
TRACE_REDIS_POOL_MAX_WAIT=-1ms

# JWT
# Use a high-entropy random value with at least 32 bytes; never use the dev/test defaults in prod.
TRACE_JWT_SECRET=<replace-with-strong-random-secret-at-least-32-chars>
TRACE_JWT_EXPIRATION_HOURS=2
TRACE_JWT_REMEMBER_EXPIRATION_DAYS=1

# CORS
TRACE_CORS_ALLOWED_ORIGINS=https://<frontend-domain>
TRACE_CORS_ALLOWED_ORIGIN_PATTERNS=
TRACE_CORS_ALLOW_CREDENTIALS=true

# Trace signature keys
# dev/test profile 默认 auto-generate=true（开箱即用、跨平台，但每次重启 key 变化）。
# Production must point to externally provisioned key files outside the source workspace and set auto-generate=false.
# Local dev/test 想用稳定密钥时，把下面的 path 取消注释并指向真实文件即可（且把 AUTO_GENERATE 改成 false）。
TRACE_SIGNATURE_PRIVATE_KEY_PATH=<replace-with-private-key-path>
TRACE_SIGNATURE_PUBLIC_KEY_PATH=<replace-with-public-key-path>
TRACE_SIGNATURE_KEY_ID=default
TRACE_SIGNATURE_KEY_VERSION=1
TRACE_SIGNATURE_AUTO_GENERATE=false

# Demo data admin endpoints
# Keep disabled outside explicit dev/test scenarios. Max count can be lowered, but the application hard-caps it at 500.
TRACE_DEMO_DATA_ENABLED=false
TRACE_DEMO_DATA_MAX_GENERATE_COUNT=500

# Batch commit tuning for produce-assign + demo-data generation (T-P1-01)
# Default 50; valid range [1, 500]. Smaller chunks = shorter per-transaction connection holding,
# more transactions; larger chunks = the opposite. quantity=500 with default produces 10 sub-transactions.
TRACE_BATCH_COMMIT_SIZE=50

# Logging
# Keep production security logs at INFO or WARN; use DEBUG only in dev/test.
TRACE_SECURITY_LOG_LEVEL=INFO
