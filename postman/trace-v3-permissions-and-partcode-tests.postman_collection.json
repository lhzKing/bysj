{
  "info": {
    "name": "溯源系统V3 - 细粒度权限+part_code测试",
    "description": "测试新特性：\n1. 细粒度权限 (trace:inbound/outbound/transfer)\n2. part_code 生产赋码\n3. keyword 统一搜索\n4. 增强版 VerifyError",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. 用户登录获取Token",
      "item": [
        {
          "name": "1.1 producer 登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Producer 登录成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "    pm.expect(jsonData.data.token).to.be.a('string');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('producerToken', jsonData.data.token);",
                  "    console.log('Saved producerToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"producer\",\n    \"password\": \"producer123456\",\n    \"rememberMe\": false\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "1.2 warehouse 登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Warehouse 登录成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('warehouseToken', jsonData.data.token);",
                  "    console.log('Saved warehouseToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"warehouse\",\n    \"password\": \"warehouse123456\",\n    \"rememberMe\": false\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "1.3 logistics 登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logistics 登录成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('logisticsToken', jsonData.data.token);",
                  "    console.log('Saved logisticsToken');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"logistics\",\n    \"password\": \"logistics123456\",\n    \"rememberMe\": false\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "2. Part keyword统一搜索",
      "item": [
        {
          "name": "2.1 使用keyword搜索（匹配part_code+part_name）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Keyword搜索成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "    pm.expect(jsonData.data.list).to.be.an('array');",
                  "    pm.expect(jsonData.data.list.length).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{producerToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/parts?page=1&size=10&keyword=VALVE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "parts"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "size", "value": "10"},
                {"key": "keyword", "value": "VALVE"}
              ]
            }
          }
        },
        {
          "name": "2.2 旧方式partCode搜索（向后兼容）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('PartCode搜索成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{producerToken}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/parts?page=1&size=10&partCode=SPU-VALVE-001",
              "host": ["{{baseUrl}}"],
              "path": ["api", "parts"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "size", "value": "10"},
                {"key": "partCode", "value": "SPU-VALVE-001"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. 生产赋码（part_code支持）",
      "item": [
        {
          "name": "3.1 使用 part_code 赋码（推荐）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Part_code赋码成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "    pm.expect(jsonData.data.trace_codes).to.be.an('array');",
                  "    pm.expect(jsonData.data.trace_codes.length).to.eql(1);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('traceCode1', jsonData.data.trace_codes[0]);",
                  "    console.log('Saved traceCode1:', jsonData.data.trace_codes[0]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{producerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"part_code\": \"SPU-VALVE-001\",\n    \"manufacturer_node\": \"浙江工厂A\",\n    \"province\": \"浙江省\",\n    \"city\": \"杭州市\",\n    \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/api/traces"
          }
        },
        {
          "name": "3.2 使用 spu_id 赋码（兼容旧方式）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Spu_id赋码成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('traceCode2', jsonData.data.trace_codes[0]);",
                  "    console.log('Saved traceCode2:', jsonData.data.trace_codes[0]);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{producerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"spu_id\": 1,\n    \"manufacturer_node\": \"江苏工厂B\",\n    \"province\": \"江苏省\",\n    \"city\": \"苏州市\",\n    \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/api/traces"
          }
        },
        {
          "name": "3.3 错误场景 - 两个参数都不提供",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('缺少参数报错', function() {",
                  "    pm.expect(pm.response.code).to.eql(400);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('至少提供一个');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{producerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"manufacturer_node\": \"广东工厂C\",\n    \"province\": \"广东省\",\n    \"city\": \"深圳市\",\n    \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/api/traces"
          }
        }
      ]
    },
    {
      "name": "4. 细粒度权限测试",
      "item": [
        {
          "name": "4.1 仓库人员 - 入库（应成功）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Warehouse INBOUND成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{warehouseToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"action_type\": \"INBOUND\",\n    \"to_node\": \"上海仓库A\",\n    \"province\": \"上海市\",\n    \"city\": \"上海市\"\n}"
            },
            "url": "{{baseUrl}}/api/traces/{{traceCode1}}/events"
          }
        },
        {
          "name": "4.2 仓库人员 - 出库（应成功）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Warehouse OUTBOUND成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{warehouseToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"action_type\": \"OUTBOUND\",\n    \"from_node\": \"上海仓库A\",\n    \"to_node\": \"发往物流中心\",\n    \"province\": \"上海市\",\n    \"city\": \"上海市\"\n}"
            },
            "url": "{{baseUrl}}/api/traces/{{traceCode1}}/events"
          }
        },
        {
          "name": "4.3 物流人员 - 流转（应成功）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logistics TRANSFER成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{logisticsToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"action_type\": \"TRANSFER\",\n    \"from_node\": \"物流中心\",\n    \"to_node\": \"北京配送站\",\n    \"province\": \"北京市\",\n    \"city\": \"北京市\"\n}"
            },
            "url": "{{baseUrl}}/api/traces/{{traceCode2}}/events"
          }
        },
        {
          "name": "4.4 物流人员 - 尝试入库（应失败）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logistics INBOUND权限不足', function() {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('权限');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{logisticsToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"action_type\": \"INBOUND\",\n    \"to_node\": \"北京仓库X\",\n    \"province\": \"北京市\",\n    \"city\": \"北京市\"\n}"
            },
            "url": "{{baseUrl}}/api/traces/{{traceCode2}}/events"
          }
        }
      ]
    },
    {
      "name": "5. 溯源链验证（增强版VerifyError）",
      "item": [
        {
          "name": "5.1 查询溯源详情",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('查询溯源详情成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "    pm.expect(jsonData.data.history).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{producerToken}}"}],
            "url": "{{baseUrl}}/api/traces/{{traceCode1}}"
          }
        },
        {
          "name": "5.2 验证溯源链（增强版VerifyError）",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('验证溯源链成功', function() {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(0);",
                  "    pm.expect(jsonData.data).to.have.property('valid');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{producerToken}}"}],
            "url": "{{baseUrl}}/api/traces/{{traceCode1}}/verify"
          }
        }
      ]
    }
  ]
}
