# ====== 复制为 .env 并填好 ======
# 千万不要把真正的 .env 提交到 git

# ---- MySQL ----
TRACE_DB_NAME=trace_db
TRACE_DB_USERNAME=trace_user
TRACE_DB_PASSWORD=please-change-me-strong
TRACE_DB_ROOT_PASSWORD=please-change-me-root

# ---- Redis ----
TRACE_REDIS_PASSWORD=please-change-me-redis

# ---- JWT secret（≥32 字节，prod profile guard 会校验）----
# 生成命令： openssl rand -base64 48
TRACE_JWT_SECRET=replace-with-openssl-rand-base64-48-output

# ---- RSA 签名密钥元数据（prod guard 强制必填，用于审计与未来密钥轮换）----
# KEY_ID：当前密钥的逻辑标识，建议带环境+日期/版本号
# KEY_VERSION：正整数，每次轮换密钥时 +1
TRACE_SIGNATURE_KEY_ID=trace-prod-2026-05
TRACE_SIGNATURE_KEY_VERSION=1

# ---- 域名（与下方 OpenResty 反代规则一致；都走 Cloudflare CDN）----
# 前端入口
TRACE_PUBLIC_BASE_URL=https://trace.coldhz.codes

# 后端 CORS 白名单（前端可能用到的所有 origin，逗号分隔；必须带 scheme，不带尾斜杠）
TRACE_CORS_ALLOWED_ORIGINS=https://trace.coldhz.codes
TRACE_CORS_ALLOWED_ORIGIN_PATTERNS=

# ---- 高德地图 Web JS Key（构建时注入前端镜像）----
VITE_AMAP_KEY=your-amap-key

# ---- 宿主机端口绑定（仅 127.0.0.1 监听，靠 OpenResty 反代）----
# 默认 18080/18081，避开 1Panel(23562)、new-api(5000)、SSH(9683)
HOST_FRONTEND_PORT=18080
HOST_BACKEND_PORT=18081
