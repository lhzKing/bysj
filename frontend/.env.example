# Vite dev server
VITE_DEV_HOST=0.0.0.0
VITE_DEV_PORT=5173
VITE_DEV_HTTPS=true

# HTTPS certificate paths relative to frontend/
VITE_DEV_CERT_KEY=certs/localhost.key
VITE_DEV_CERT_CERT=certs/localhost.crt

# API proxy target
VITE_API_PROXY_TARGET=http://localhost:8080

# AMap JS API key used by TraceRouteMap.vue
VITE_AMAP_KEY=<replace-with-amap-web-js-api-key>
